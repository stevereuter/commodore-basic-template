{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build project + d64",
            "dependsOrder": "sequence",
            "dependsOn": [
                "vs64 build prg",
                "create d64 image",
                "add configured binaries"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "vs64 build prg",
            "type": "vs64",
            "action": "build",
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "create d64 image",
            "type": "shell",
            "command": "c1541",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "-format",
                "basic-template,00",
                "d64",
                "build/basic-template.d64",
                "-write",
                "build/basic-template.prg",
                "basic-template"
            ],
            "problemMatcher": []
        },
        {
            "label": "add configured binaries",
            "type": "shell",
            "command": "python3",
            "args": ["${workspaceFolder}/tools/add_config_binaries.py"],
            "problemMatcher": []
        }
    ]
}
